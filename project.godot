; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Quantum Coffee"
run/main_scene="res://node_2d.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

DialogueManager="*uid://c3rodes2l3gxb"

[dialogue_manager]

runtime/balloon_path="res:///balloon.tscn"

[display]

window/size/mode=3

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[internationalization]

locale/translations_pot_files=PackedStringArray("res://dialogue0.dialogue", "res://Level0.dialogue", "res://Level1.dialogue", "res://Level0-B.dialogue", "res://Level-B.dialogue", "res://Level1-B.dialogue", "res://Level2.dialogue", "res://Level2 - B.dialogue", "res://Level2-B.dialogue", "res://Final.dialogue")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
